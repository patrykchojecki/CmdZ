{
  "manifest_version": 3,
  "name": "CmdZ",
  "version": "1.0.5",
  "description": "Reopen closed tabs with Command+Z without overriding page undo.",
  "homepage_url": "https://github.com/patrykchojecki/CmdZ",
  "minimum_chrome_version": "96",
  "permissions": ["sessions", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Reopen the most recently closed tab"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["recovery.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
